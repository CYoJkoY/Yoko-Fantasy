[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type canvas_item;

uniform vec4 tint_color : hint_color = vec4(1.0, 0.88, 0.38, 1.0);
uniform vec4 center_color : hint_color = vec4(1.0, 1.0, 0.92, 1.0);
uniform float tint_strength : hint_range(0.0, 1.0) = 0.45;

void fragment() {
	vec4 tex = texture(TEXTURE, UV);
	float center = 1.0 - smoothstep(0.0, 0.42, abs(UV.x - 0.5));
	vec3 holy_color = mix(tint_color.rgb, center_color.rgb, center);
	vec3 final_rgb = mix(tex.rgb, holy_color, tint_strength);
	COLOR = vec4(final_rgb, tex.a * COLOR.a);
}"

[resource]
shader = SubResource( 1 )
shader_param/tint_color = Color( 1, 0.88, 0.38, 1 )
shader_param/center_color = Color( 1, 1, 0.92, 1 )
shader_param/tint_strength = 0.45
