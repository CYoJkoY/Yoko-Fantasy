[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type canvas_item;
render_mode blend_add;

void fragment() {
	vec2 uv = UV;
	float t = TIME;
	float sword_core = 1.0 - smoothstep(0.04, 0.34, distance(uv, vec2(0.47, 0.47)));
	float hero_pool = 1.0 - smoothstep(0.08, 0.58, distance(uv, vec2(0.55, 0.62)));
	float sweep_a = 1.0 - smoothstep(0.00, 0.030, abs(uv.x * 1.25 + uv.y * 0.55 - (0.58 + 0.045 * sin(t * 0.78))));
	float sweep_b = 1.0 - smoothstep(0.00, 0.024, abs(uv.x * 1.10 - uv.y * 0.42 - (0.05 + 0.035 * sin(t * 0.58 + 1.7))));
	float pulse = 0.62 + 0.38 * sin(t * 2.25 + uv.x * 5.8 + uv.y * 3.0);
	float alpha = sword_core * (0.055 + 0.050 * pulse) + hero_pool * 0.030 + max(sweep_a, sweep_b) * 0.060;
	COLOR = vec4(0.92, 1.0, 0.42, clamp(alpha, 0.0, 0.18) * COLOR.a);
}
"

[resource]
shader = SubResource( 1 )
