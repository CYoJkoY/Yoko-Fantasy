[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type canvas_item;

void fragment() {
	vec2 uv = UV;
	float t = TIME;
	float forest = smoothstep(0.02, 0.14, uv.y) * (1.0 - smoothstep(0.66, 0.88, uv.y));
	float upper = 1.0 - smoothstep(0.32, 0.66, uv.y);
	float right_depth = smoothstep(0.46, 0.96, uv.x);
	float moving_edge = 1.0 - smoothstep(0.00, 0.18, abs(uv.y - (0.52 + 0.035 * sin(t * 0.55 + uv.x * 4.2))));
	float maze = 0.5 + 0.5 * sin(t * 0.48 + uv.x * 11.0 - uv.y * 7.0);
	float alpha = forest * (upper * 0.40 + right_depth * 0.20 + moving_edge * 0.12 + maze * 0.08);
	COLOR = vec4(0.0, 0.008, 0.003, clamp(alpha, 0.0, 0.66) * COLOR.a);
}
"

[resource]
shader = SubResource( 1 )
