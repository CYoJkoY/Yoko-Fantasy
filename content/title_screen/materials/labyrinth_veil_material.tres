[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type canvas_item;

void fragment() {
	vec2 uv = UV;
	float t = TIME;
	float forest = 1.0 - smoothstep(0.44, 0.64, uv.y);
	float depth = (1.0 - smoothstep(0.58, 0.96, uv.y)) * forest;
	float lane_a = 1.0 - smoothstep(0.00, 0.145, abs(sin((uv.x * 5.4 + uv.y * 1.7 + t * 0.34) * 3.14159)));
	float lane_b = 1.0 - smoothstep(0.00, 0.120, abs(sin((uv.x * 7.2 - uv.y * 2.2 - t * 0.27) * 3.14159)));
	float lane_c = 1.0 - smoothstep(0.00, 0.105, abs(sin((uv.x * 3.0 + uv.y * 5.0 + t * 0.21) * 3.14159)));
	float cross = max(max(lane_a, lane_b * 0.9), lane_c * 0.75);
	float veil = 1.0 - smoothstep(0.00, 0.31, abs(sin(uv.x * 15.0 + sin(uv.y * 8.0) + t * 0.48)));
	float pocket = forest * (0.50 + 0.50 * sin(t * 0.78 + uv.x * 9.0 + uv.y * 4.0));
	float shade_gradient = smoothstep(0.02, 0.42, uv.y) * (1.0 - smoothstep(0.62, 0.80, uv.y));
	float dark = (cross * 0.50 + veil * 0.20 + shade_gradient * 0.22) * depth;
	float green = pocket * 0.040 * (1.0 - depth * 0.12);
	COLOR = vec4(0.0, 0.024 + green, 0.008, clamp(dark + green, 0.0, 0.68));
}
"

[resource]
shader = SubResource( 1 )
