[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type canvas_item;

uniform vec2 gem_center = vec2(0.500, 0.219);

void fragment() {
	vec2 uv = UV;
	float t = TIME;
	vec2 p = uv - gem_center;
	p.x *= 1.78;
	float d = length(p);
	float pulse = 0.72 + 0.28 * sin(t * 0.82);
	float slow = 0.5 + 0.5 * sin(t * 0.34 + 1.4);
	float inner_haze = smoothstep(0.068, 0.010, d) * 0.12;
	float aura = smoothstep(0.135, 0.035, d) * (0.070 + 0.038 * pulse);
	float ring_a = smoothstep(0.0045, 0.0000, abs(d - 0.082));
	float ring_b = smoothstep(0.0050, 0.0000, abs(d - 0.142));
	float ring_c = smoothstep(0.0070, 0.0000, abs(d - 0.222));
	float ring_d = smoothstep(0.0060, 0.0000, abs(d - 0.292));
	float lens = ring_a * 0.19 + ring_b * (0.130 + 0.038 * pulse) + ring_c * (0.060 + 0.030 * slow) + ring_d * (0.030 + 0.016 * pulse);
	float alpha = inner_haze + aura + lens;
	vec3 ruby = vec3(1.0, 0.15, 0.08);
	vec3 gold = vec3(1.0, 0.72, 0.22);
	vec3 color = mix(ruby, gold, clamp(d * 5.2 + slow * 0.12, 0.0, 1.0));
	COLOR = vec4(color, alpha) * COLOR;
}
"

[resource]
shader = SubResource( 1 )
shader_param/gem_center = Vector2( 0.5, 0.219 )
