[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type canvas_item;

uniform vec2 gem_center = vec2(0.500, 0.219);

float dot_at(vec2 p, vec2 c, float radius) {
	return smoothstep(radius, 0.0, length(p - c));
}

void fragment() {
	vec2 uv = UV;
	float t = TIME;
	vec2 p = uv - gem_center;
	p.x *= 1.78;
	float breathe = 0.72 + 0.28 * sin(t * 0.52);
	vec2 wobble = vec2(sin(t * 0.52), cos(t * 0.43)) * 0.004;
	float a = 0.0;
	vec3 color = vec3(0.0);
	float d1 = dot_at(p, vec2(-0.105, -0.030) + wobble, 0.012);
	float d2 = dot_at(p, vec2(0.132, 0.018) - wobble * 0.8, 0.010);
	float d3 = dot_at(p, vec2(-0.030, 0.118) + wobble.yx * 0.6, 0.008);
	float d4 = dot_at(p, vec2(0.060, -0.138) - wobble.yx * 0.7, 0.007);
	color += d1 * vec3(1.0, 0.42, 0.75);
	color += d2 * vec3(1.0, 0.84, 0.28);
	color += d3 * vec3(0.56, 0.92, 1.0);
	color += d4 * vec3(1.0, 0.98, 0.66);
	a = (d1 + d2 + d3 + d4) * (0.22 + 0.12 * breathe);
	COLOR = vec4(color, a) * COLOR;
}
"

[resource]
shader = SubResource( 1 )
