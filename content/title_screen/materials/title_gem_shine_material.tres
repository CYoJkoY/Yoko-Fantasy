[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type canvas_item;

uniform vec2 gem_center = vec2(0.500, 0.219);

void fragment() {
	vec2 uv = UV;
	float t = TIME;
	vec2 p = uv - gem_center;
	p.x *= 1.78;
	float d = length(p);
	float gem_mask = smoothstep(0.090, 0.012, d);
	float cycle = mod(t + 1.3, 7.2);
	float run = smoothstep(0.15, 0.75, cycle) * (1.0 - smoothstep(1.25, 1.95, cycle));
	float sweep_pos = mix(-0.105, 0.105, clamp((cycle - 0.15) / 1.55, 0.0, 1.0));
	float diagonal = p.x * 0.58 + p.y * 1.10;
	float band = smoothstep(0.020, 0.000, abs(diagonal - sweep_pos));
	float flash = smoothstep(1.28, 1.62, cycle) * (1.0 - smoothstep(1.62, 2.28, cycle));
	float alpha = gem_mask * (band * run * 0.52 + flash * smoothstep(0.075, 0.000, d) * 0.32);
	vec3 color = mix(vec3(1.0, 0.88, 0.58), vec3(1.0, 1.0, 1.0), band);
	COLOR = vec4(color, alpha) * COLOR;
}
"

[resource]
shader = SubResource( 1 )
