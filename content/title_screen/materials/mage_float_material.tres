[gd_resource type="ShaderMaterial" load_steps=2 format=2]

[sub_resource type="Shader" id=1]
code = "shader_type canvas_item;

void fragment() {
	vec2 uv = UV;
	float t = TIME;
	float mage = 1.0 - smoothstep(0.08, 0.36, distance(uv, vec2(0.66, 0.52)));
	float staff = 1.0 - smoothstep(0.05, 0.28, distance(uv, vec2(0.79, 0.34)));
	float mask = max(mage, staff);
	float bob = sin(t * 2.05);
	vec2 offset = vec2(0.0014 * sin(t * 1.05 + 0.4), 0.0068 * bob);
	vec4 tex = texture(TEXTURE, uv + offset * mask);
	COLOR = tex * COLOR;
}
"

[resource]
shader = SubResource( 1 )
